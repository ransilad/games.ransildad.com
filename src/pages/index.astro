---
import Layout from '../layouts/Layout.astro';

const games = [
	{
		title: 'Tres en Raya',
		status: 'Listo para jugar',
		state: 'live',
		type: 'Duelo táctico',
		description:
			'El clásico duelo de ingenio reimaginado como una partida rápida, pulida y lista para competir contra otra mente estratégica.',
		cta: 'Jugar ahora',
		href: 'https://tres-en-raya.ransilad.com/',
		meta: ['2 jugadores', 'Clásico', 'Estrategia'],
		progress: null,
	},
	{
		title: 'Stop (Bachillerato)',
		status: 'Próximamente',
		state: 'soon',
		type: 'Letras contra reloj',
		description:
			'Carreras de vocabulario por categorías, presión de tiempo y rondas rápidas para competir con amigos.',
		cta: null,
		href: null,
		meta: ['Palabras', 'Multironda', 'Social'],
		progress: null,
	},
	{
		title: 'El Ahorcado',
		status: 'Próximamente',
		state: 'development',
		type: 'Deducción verbal',
		description:
			'Una reinvención sobria del juego de adivinar palabras, con tensión visual y pistas diseñadas para partidas cortas.',
		cta: null,
		href: null,
		meta: ['Vocabulario', 'Solo'],
		progress: null,
	},
];

const featuredGame = games[0];
const secondaryGames = games.slice(1);
---

<Layout
	title="Ransilad Games | Universo de Juegos"
	description="Explora el universo de juegos independientes de Ransilad: títulos jugables, proyectos en desarrollo y próximos lanzamientos."
>
	<main class="arcade-shell">
		<section class="hero" aria-labelledby="page-title">
			<p class="eyebrow">Archivo interactivo / juegos de autor</p>
			<div class="hero-copy">
				<h1 id="page-title">Mi universo <span>de juegos</span></h1>
				<p>
					Entra en una sala digital de juegos independientes: clásicos reimaginados,
					prototipos en marcha y pequeñas experiencias diseñadas con precisión.
				</p>
			</div>
		</section>

		<section id="juegos" class="catalog" aria-labelledby="catalog-title">
			<div class="section-heading">
				<p class="eyebrow">Selección actual</p>
				<h2 id="catalog-title">Juegos disponibles y próximos experimentos</h2>
			</div>

			<div class="games-grid">
				<article id="tres-en-raya" class="game-card compact-card" aria-labelledby="featured-title">
					<div class="compact-icon" aria-hidden="true">TR</div>
					<div class="card-body">
						<div class="card-topline">
							<span class={`status ${featuredGame.state}`}>{featuredGame.status}</span>
							<span>{featuredGame.type}</span>
						</div>
						<h3 id="featured-title">{featuredGame.title}</h3>
						<p>{featuredGame.description}</p>
						<ul class="chips" aria-label={`Detalles de ${featuredGame.title}`}>
							{featuredGame.meta.map((item) => <li>{item}</li>)}
						</ul>
						<a
							class="play-link"
							href={featuredGame.href}
							aria-label={`Jugar ${featuredGame.title}`}
							target="_blank"
							rel="noopener noreferrer"
						>
							{featuredGame.cta}
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</article>

				{
					secondaryGames.map((game) => (
						<article class="game-card compact-card">
							<div class="compact-icon" aria-hidden="true">
								{game.state === 'soon' ? 'ST' : 'AH'}
							</div>
							<div class="card-topline">
								<span class={`status ${game.state}`}>{game.status}</span>
								<span>{game.type}</span>
							</div>
							<h3>{game.title}</h3>
							<p>{game.description}</p>
							<ul class="chips" aria-label={`Detalles de ${game.title}`}>
								{game.meta.map((item) => <li>{item}</li>)}
							</ul>
						</article>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		color: #dae2fd;
		font-family:
			'Plus Jakarta Sans', 'Avenir Next', Avenir, 'Segoe UI', sans-serif;
		overflow-x: hidden;
	}

	:global(a) {
		color: inherit;
	}

	:global(:focus-visible) {
		outline: 3px solid #4edea3;
		outline-offset: 4px;
	}

	.arcade-shell {
		position: relative;
		min-height: 100vh;
		padding: 48px clamp(18px, 5vw, 80px) 72px;
		background:
			radial-gradient(circle at 16% 10%, rgba(208, 188, 255, 0.2), transparent 30%),
			radial-gradient(circle at 82% 18%, rgba(78, 222, 163, 0.16), transparent 28%),
			linear-gradient(135deg, #060e20 0%, #0b1326 48%, #131b2e 100%);
		isolation: isolate;
	}

	.arcade-shell::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		content: '';
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
		background-size: 56px 56px;
		mask-image: linear-gradient(to bottom, black, transparent 82%);
	}

	.hero,
	.catalog {
		width: min(100%, 1280px);
		margin: 0 auto;
	}

	.hero {
		padding: clamp(42px, 7vw, 88px) 0 34px;
	}

	.eyebrow,
	.card-topline,
	.chips,
	.locked-note,
	.status {
		font-family: 'JetBrains Mono', 'Cascadia Code', 'SFMono-Regular', monospace;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.eyebrow {
		margin: 0 0 18px;
		color: #4edea3;
	}

	h1,
	h2,
	h3 {
		font-family: Sora, 'Archivo Black', 'Trebuchet MS', sans-serif;
		margin: 0;
		color: #f3f5ff;
		line-height: 1.02;
	}

	h1 {
		max-width: 920px;
		font-size: clamp(3.4rem, 10vw, 8.6rem);
		font-weight: 800;
		letter-spacing: -0.08em;
		text-wrap: balance;
	}

	h1 span {
		display: block;
		color: #d0bcff;
		text-shadow: 0 20px 70px rgba(208, 188, 255, 0.24);
	}

	.hero-copy p {
		max-width: 690px;
		margin: 26px 0 0;
		color: #cbc3d7;
		font-size: clamp(1rem, 2vw, 1.25rem);
		line-height: 1.75;
	}

	.game-card {
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: linear-gradient(145deg, rgba(34, 42, 61, 0.7), rgba(19, 27, 46, 0.58));
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.34);
		backdrop-filter: blur(28px);
	}

	.catalog {
		padding-top: clamp(28px, 5vw, 64px);
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 28px;
	}

	.section-heading .eyebrow {
		margin: 0;
	}

	.section-heading h2 {
		max-width: 760px;
		font-size: clamp(2rem, 4vw, 4rem);
		letter-spacing: -0.05em;
		text-align: right;
	}

	.games-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 24px;
		align-items: stretch;
	}

	.game-card {
		position: relative;
		overflow: hidden;
		border-radius: 24px;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			background 0.2s ease;
	}

	.game-card:hover {
		border-color: rgba(208, 188, 255, 0.45);
		transform: translateY(-3px);
	}

	.card-content,
	.card-body,
	.compact-card {
		display: flex;
		flex-direction: column;
	}

	.card-content {
		justify-content: center;
		padding: clamp(26px, 4vw, 48px);
		background: rgba(6, 14, 32, 0.38);
	}

	.card-topline {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
		margin-bottom: 18px;
		color: #958ea0;
	}

	.status {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: #dae2fd;
	}

	.status::before {
		width: 8px;
		height: 8px;
		border-radius: 999px;
		content: '';
		background: currentColor;
	}

	.status.live {
		color: #4edea3;
	}

	.status.soon {
		color: #ffafd3;
	}

	.status.development {
		color: #d0bcff;
	}

	.game-card h3 {
		font-size: clamp(1.65rem, 3vw, 3.4rem);
		letter-spacing: -0.04em;
	}

	.game-card p {
		display: -webkit-box;
		overflow: hidden;
		min-height: calc(1.7em * 3);
		margin: 18px 0 0;
		color: #cbc3d7;
		font-size: 1rem;
		line-height: 1.7;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
	}

	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0;
		margin: 24px 0 0;
		list-style: none;
	}

	.chips li {
		padding: 8px 10px;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.07);
		color: #dae2fd;
	}

	.play-link {
		display: inline-flex;
		align-items: center;
		align-self: flex-end;
		gap: 10px;
		margin-top: 32px;
		padding: 14px 16px;
		border: 1px solid rgba(208, 188, 255, 0.42);
		border-radius: 10px;
		background: linear-gradient(135deg, rgba(208, 188, 255, 0.22), rgba(78, 222, 163, 0.08));
		color: #f3f5ff;
		font-family: 'JetBrains Mono', 'Cascadia Code', monospace;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.play-link:hover {
		border-color: #4edea3;
		background: linear-gradient(135deg, rgba(208, 188, 255, 0.3), rgba(78, 222, 163, 0.16));
		transform: translateX(3px);
	}

	.compact-card {
		padding: 26px;
	}

	.compact-icon {
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		margin-bottom: 24px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.07);
		color: #4edea3;
		font-family: 'JetBrains Mono', monospace;
		font-weight: 800;
	}

	.compact-card h3 {
		font-size: 1.55rem;
	}

	@media (max-width: 980px) {
		.games-grid {
			grid-template-columns: 1fr;
		}

		.section-heading {
			display: block;
		}

		.section-heading h2 {
			text-align: left;
		}

		.section-heading .eyebrow {
			margin: 0 0 18px;
		}
	}

	@media (max-width: 640px) {
		.arcade-shell {
			padding-top: 30px;
		}

		.hero {
			padding-top: 34px;
		}

		.card-content,
		.compact-card {
			padding: 20px;
		}

	}
</style>
