---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
	robots?: string;
}

const {
	title = 'Ransilad Games',
	description = 'Explora juegos independientes creados por Ransilad.',
	image = '/og-image.webp',
	canonical,
	robots = 'index, follow, max-image-preview:large',
} = Astro.props;

const site = Astro.site ?? new URL('https://games.ransilad.com');
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site).toString();
const imageUrl = image ? new URL(image, site).toString() : undefined;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700;800&family=Plus+Jakarta+Sans:wght@400;600;700&family=Sora:wght@600;700;800&display=swap"
			rel="stylesheet"
		/>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#0b1326" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Ransilad Games" />
		<meta property="og:locale" content="es_MX" />
		{imageUrl && <meta property="og:image" content={imageUrl} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{imageUrl && <meta name="twitter:image" content={imageUrl} />}
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		background: #0b1326;
	}
</style>
